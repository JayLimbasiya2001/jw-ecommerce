# --- Neon / cloud PostgreSQL (recommended) ---
# Paste your Neon connection string from the dashboard (includes sslmode).
# When set, DB_HOST / DB_USER / DB_PASS / DB_NAME are ignored by Sequelize.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Local PostgreSQL (only if DATABASE_URL is not set) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=jewelry_db
# DB_USER=postgres
# DB_PASS=admin

# Set to "true" to log SQL queries
# DB_LOGGING=false

# JWT secret for auth (required for login/register)
JWT_SECRET=your_jwt_secret_key

# Server port
# PORT=4000

# Public API URL (webhooks, GoKwik callbacks)
# APP_URL=http://localhost:4000
# FRONTEND_URL=http://localhost:3000

# --- GoKwik payment gateway (sandbox for dev) ---
# Enable GoKwik checkout (set credentials from Merchant Dashboard → Account)
GOKWIK_ENABLED=true
GOKWIK_ENV=SANDBOX
GOKWIK_APP_ID=your_gokwik_app_id
GOKWIK_APP_SECRET=your_gokwik_app_secret
GOKWIK_MERCHANT_ID=your_merchant_id
# Webhook HMAC secret (from GoKwik dashboard); optional in sandbox
GOKWIK_WEBHOOK_SECRET=
# Dev: skip real API calls and return mock checkout payload
GOKWIK_MOCK_CHECKOUT=true
# Optional: override API base (defaults by GOKWIK_ENV)
# GOKWIK_API_BASE_URL=https://api-gw-v4.dev.gokwik.io/sandbox/
# Optional RTO risk API before payment methods
# GOKWIK_RTO_ENABLED=false
# Dev only: accept webhooks without signature when MOCK is on
# GOKWIK_WEBHOOK_SKIP_VERIFY=true
